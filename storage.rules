rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Menü görselleri: herkes okur (menüde gösterilir).
    // Yazma şimdilik açık (test modu). Üretimde Auth ile sınırla.
    match /menu/{file} {
      allow read: if true;
      allow write: if request.resource == null
                   || (request.resource.size < 5 * 1024 * 1024
                       && request.resource.contentType.matches('image/.*'));
    }
  }
}
